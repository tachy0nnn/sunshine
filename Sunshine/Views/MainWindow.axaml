<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Sunshine.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:material="using:Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="280"
        x:Class="Sunshine.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Sunshine"
        Width="560" Height="280"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a1a"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Button.NavButton">
            <Setter Property="Background" Value="#2a2a2a" />
            <Setter Property="Foreground" Value="#e0e0e0" />
            <Setter Property="BorderBrush" Value="#3a3a3a" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Height" Value="52" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.NavButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#333333" />
        </Style>
        <Style Selector="Button.NavButton:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#222222" />
        </Style>

        <Style Selector="Button.LinkButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#f0c040" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.LinkButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="220,*">

        <!-- drag region -->
        <Panel Grid.ColumnSpan="2"
               VerticalAlignment="Top"
               Height="32"
               Background="Transparent"
               PointerPressed="OnTitleBarPointerPressed" />

        <!-- close button -->
        <Button Grid.ColumnSpan="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Width="46" Height="32"
                Background="Transparent"
                BorderThickness="0"
                Foreground="#666"
                Cursor="Hand"
                Click="OnCloseClicked"
                ZIndex="10">
            <material:MaterialIcon Kind="Close" Width="8" Height="8" />
        </Button>

        <!-- left panel -->
        <StackPanel Grid.Column="0"
                    Margin="28,40,20,24"
                    VerticalAlignment="Center"
                    Spacing="0">

            <StackPanel Orientation="Horizontal" Spacing="14" Margin="0,0,0,28">
                <Border Width="52" Height="52" CornerRadius="12" Background="#ffffff">
                    <Image Source="/Assets/avalonia-logo.ico"
                           Width="32" Height="32"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="Sunshine"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="#e8e8e8" />
                    <TextBlock Text="Version 1.0.0"
                               FontSize="12"
                               Foreground="#555" />
                </StackPanel>
            </StackPanel>

            <Button Classes="LinkButton" Margin="0,0,0,10" Click="OnAboutClicked">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <material:MaterialIcon Kind="InformationOutline" Width="16" Height="16"
                                           Foreground="#f0c040" VerticalAlignment="Center" />
                    <TextBlock Text="About Sunshine" FontSize="13" Foreground="#f0c040" />
                </StackPanel>
            </Button>

        </StackPanel>

        <!-- right panel -->
        <StackPanel Grid.Column="1"
                    Margin="8,0,20,0"
                    VerticalAlignment="Center"
                    Spacing="8">

            <!-- launch roblox -->
            <Button Classes="NavButton" Command="{Binding LaunchCommand}">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <material:MaterialIcon Grid.Column="0" Kind="Play" Width="18" Height="18"
                                           Foreground="#f0c040" VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                    <TextBlock Grid.Column="1" Text="Launch Roblox"
                               FontSize="14" VerticalAlignment="Center" />
                    <material:MaterialIcon Grid.Column="2" Kind="ChevronRight" Width="18" Height="18"
                                           Foreground="#555" VerticalAlignment="Center" />
                </Grid>
            </Button>

            <!-- configure settings -->
            <Button Classes="NavButton" Click="OnSettingsClicked">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <material:MaterialIcon Grid.Column="0" Kind="Cog" Width="18" Height="18"
                                           Foreground="#aaa" VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                    <TextBlock Grid.Column="1" Text="Configure settings"
                               FontSize="14" VerticalAlignment="Center" />
                    <material:MaterialIcon Grid.Column="2" Kind="ChevronRight" Width="18" Height="18"
                                           Foreground="#555" VerticalAlignment="Center" />
                </Grid>
            </Button>

            <!-- launch studio -->
            <Button Classes="NavButton" Command="{Binding LaunchStudioCommand}">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <material:MaterialIcon Grid.Column="0" Kind="Wrench" Width="18" Height="18"
                                           Foreground="#e0e0e0" VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                    <TextBlock Grid.Column="1" Text="Launch Roblox Studio"
                               FontSize="14" VerticalAlignment="Center" />
                    <material:MaterialIcon Grid.Column="2" Kind="ChevronRight" Width="18" Height="18"
                                           Foreground="#555" VerticalAlignment="Center" />
                </Grid>
            </Button>

        </StackPanel>

    </Grid>
</Window>