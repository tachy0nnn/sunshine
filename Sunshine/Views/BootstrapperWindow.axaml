<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Sunshine.ViewModels"
        x:Class="Sunshine.Views.BootstrapperWindow"
        x:DataType="vm:BootstrapperViewModel"
        Title="Sunshine"
        Width="440" Height="200"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a1a"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <!-- drag region -->
    <Panel>
        <Panel VerticalAlignment="Top" Height="32" Background="Transparent"
               PointerPressed="OnTitleBarPointerPressed" />

        <StackPanel VerticalAlignment="Center" Margin="36,0,36,0" Spacing="18">

            <!-- icon + app name -->
            <StackPanel Orientation="Horizontal" Spacing="14" HorizontalAlignment="Center">
                <Border Width="40" Height="40" CornerRadius="10" Background="#0d3d56">
                    <Image Source="/Assets/avalonia-logo.ico" Width="24" Height="24"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="Sunshine" FontSize="20" FontWeight="SemiBold"
                           Foreground="#e8e8e8" VerticalAlignment="Center" />
            </StackPanel>

            <!-- status text -->
            <TextBlock Text="{Binding StatusText}"
                       FontSize="13" Foreground="#aaa"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap" TextAlignment="Center" />

            <!-- progress bar -->
            <ProgressBar Value="{Binding Progress}"
                         Minimum="0" Maximum="1"
                         Height="6"
                         IsIndeterminate="{Binding IsIndeterminate}"
                         Foreground="#f0c040"
                         Background="#333"
                         CornerRadius="3" />

            <!-- cancel button -->
            <Button Content="Cancel"
                    HorizontalAlignment="Center"
                    Click="OnCancelClicked"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#666"
                    Cursor="Hand"
                    IsVisible="{Binding CanCancel}" />
        </StackPanel>
    </Panel>
</Window>